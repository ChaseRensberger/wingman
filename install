#!/usr/bin/env bash
set -euo pipefail

APP="wingman"
OWNER="chaserensberger"
REPO="wingman"

requested_version="${VERSION:-}"
binary_path=""
install_dir="${WINGMAN_INSTALL_DIR:-$HOME/.wingman/bin}"
no_modify_path=false
assume_yes=false
install_snapshot=false

usage() {
  cat <<'EOF'
Wingman Installer

Usage: install [options]

Options:
  -h, --help              Show help
  -v, --version <version> Install a specific version (default: latest stable release)
      --snapshot          Install the latest snapshot build from GitHub Actions
  -b, --binary <path>     Install from a local binary
      --install-dir <dir> Set install directory (default: ~/.wingman/bin)
      --no-modify-path    Do not modify shell config files
  -y, --yes               Accept default install choices

Examples:
  curl -fsSL https://wingman.actor/install | bash
  curl -fsSL https://wingman.actor/install | bash -s -- --snapshot
  curl -fsSL https://wingman.actor/install | bash -s -- --version 0.1.1
  ./install --binary ./wingman
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -v|--version)
      if [[ -z "${2:-}" ]]; then
        echo "Error: --version requires a value" >&2
        exit 1
      fi
      requested_version="$2"
      shift 2
      ;;
    --snapshot)
      install_snapshot=true
      shift
      ;;
    -b|--binary)
      if [[ -z "${2:-}" ]]; then
        echo "Error: --binary requires a path" >&2
        exit 1
      fi
      binary_path="$2"
      shift 2
      ;;
    --install-dir)
      if [[ -z "${2:-}" ]]; then
        echo "Error: --install-dir requires a value" >&2
        exit 1
      fi
      install_dir="$2"
      shift 2
      ;;
    --no-modify-path)
      no_modify_path=true
      shift
      ;;
    -y|--yes)
      assume_yes=true
      shift
      ;;
    *)
      echo "Warning: Unknown option '$1'" >&2
      shift
      ;;
  esac
done

if [[ "$install_snapshot" == true && -n "$requested_version" ]]; then
  echo "Error: --snapshot cannot be combined with --version" >&2
  exit 1
fi

if [[ "$install_snapshot" == true && -n "$binary_path" ]]; then
  echo "Error: --snapshot cannot be combined with --binary" >&2
  exit 1
fi

is_interactive() {
  [[ -t 0 && -t 1 && "$assume_yes" == false ]]
}

confirm() {
  local prompt="$1" default="$2" answer
  if ! is_interactive; then
    [[ "$default" == "yes" ]]
    return
  fi

  if [[ "$default" == "yes" ]]; then
    read -r -p "${prompt} [Y/n] " answer
    [[ -z "$answer" || "$answer" =~ ^[Yy]$ ]]
  else
    read -r -p "${prompt} [y/N] " answer
    [[ "$answer" =~ ^[Yy]$ ]]
  fi
}

if is_interactive; then
  echo "Wingman will install to: ${install_dir}"
  if ! confirm "Continue?" yes; then
    echo "Install cancelled"
    exit 0
  fi
fi

mkdir -p "$install_dir"

detect_os() {
  case "$(uname -s)" in
    Linux*) echo "linux" ;;
    Darwin*) echo "darwin" ;;
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    *)
      echo "Unsupported operating system" >&2
      exit 1
      ;;
  esac
}

detect_arch() {
  case "$(uname -m)" in
    x86_64|amd64) echo "amd64" ;;
    arm64|aarch64) echo "arm64" ;;
    *)
      echo "Unsupported architecture" >&2
      exit 1
      ;;
  esac
}

resolve_version() {
  if [[ -n "$requested_version" ]]; then
    echo "${requested_version#v}"
    return
  fi

  local api latest
  api="https://api.github.com/repos/${OWNER}/${REPO}/releases/latest"
  latest=$(curl -fsSL "$api" | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"v\{0,1\}\([^"]*\)".*/\1/p' | head -n 1)

  if [[ -z "$latest" ]]; then
    echo "Failed to resolve latest ${APP} release" >&2
    exit 1
  fi

  echo "$latest"
}

resolve_asset_url() {
  local version="$1" os="$2" arch="$3" ext="$4"
  local api url name candidate fallback
  api="https://api.github.com/repos/${OWNER}/${REPO}/releases/tags/v${version}"

  while IFS= read -r url; do
    [[ -z "$url" ]] && continue
    name=$(basename "$url")

    [[ "$name" != ${APP}* ]] && continue
    [[ "$name" != *".${ext}" ]] && continue
    [[ "$name" != *"${os}"* ]] && continue
    [[ "$name" != *"${arch}"* ]] && continue

    if [[ "$name" == "${APP}_${version}_${os}_${arch}.${ext}" ]]; then
      candidate="$url"
      break
    fi

    if [[ "$name" == "${APP}_.${version}_.${os}_.${arch}.${ext}" ]]; then
      candidate="$url"
      break
    fi

    if [[ -z "$fallback" ]]; then
      fallback="$url"
    fi
  done < <(curl -fsSL "$api" | sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')

  if [[ -n "$candidate" ]]; then
    echo "$candidate"
    return
  fi

  if [[ -n "$fallback" ]]; then
    echo "$fallback"
    return
  fi

  echo ""
}

github_auth_header_args() {
  local token="${GITHUB_TOKEN:-${GH_TOKEN:-}}"
  if [[ -n "$token" ]]; then
    printf '%s\n' -H "Authorization: Bearer ${token}"
  fi
}

github_api_get() {
  local url="$1"
  local -a args=()

  while IFS= read -r arg; do
    args+=("$arg")
  done < <(github_auth_header_args)

  curl -fsSL \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2022-11-28" \
    "${args[@]}" \
    "$url"
}

github_download() {
  local url="$1" output="$2"
  local -a args=()

  while IFS= read -r arg; do
    args+=("$arg")
  done < <(github_auth_header_args)

  curl -fL \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2022-11-28" \
    "${args[@]}" \
    "$url" \
    -o "$output"
}

latest_snapshot_artifact_url() {
  local api json artifact url
  api="https://api.github.com/repos/${OWNER}/${REPO}/actions/artifacts?name=${APP}-snapshot&per_page=20"
  json=$(github_api_get "$api")

  while IFS= read -r artifact; do
    [[ "$artifact" == *'"expired": false'* || "$artifact" == *'"expired":false'* ]] || continue
    url=$(printf '%s' "$artifact" | sed -n 's/.*"archive_download_url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
    if [[ -n "$url" ]]; then
      echo "$url"
      return
    fi
  done < <(printf '%s' "$json" | tr -d '\n' | sed 's/},{/}\n{/g')
}

install_from_snapshot() {
  local os arch ext tmp_dir artifact_zip artifact_url archive bin_name
  os=$(detect_os)
  arch=$(detect_arch)

  ext="tar.gz"
  if [[ "$os" == "windows" ]]; then
    ext="zip"
  fi

  artifact_url=$(latest_snapshot_artifact_url)
  if [[ -z "$artifact_url" ]]; then
    echo "Failed to resolve latest ${APP} snapshot artifact" >&2
    exit 1
  fi

  echo "Installing latest ${APP} snapshot (${os}/${arch})"

  tmp_dir=$(mktemp -d)
  artifact_zip="${tmp_dir}/${APP}-snapshot.zip"
  trap '[[ -n "${tmp_dir:-}" ]] && rm -rf "$tmp_dir"' EXIT

  if ! github_download "$artifact_url" "$artifact_zip"; then
    echo "Failed to download snapshot artifact: $artifact_url" >&2
    echo "If GitHub requires authentication, retry with GH_TOKEN set to a token that can read Actions artifacts." >&2
    exit 1
  fi

  if ! command -v unzip >/dev/null 2>&1; then
    echo "Error: unzip is required to install snapshots" >&2
    exit 1
  fi

  unzip -q "$artifact_zip" -d "$tmp_dir"
  archive=$(find "$tmp_dir" -type f -name "${APP}_*_${os}_${arch}.${ext}" | head -n 1)
  if [[ -z "$archive" ]]; then
    echo "Snapshot artifact does not contain a ${os}/${arch} archive" >&2
    exit 1
  fi

  if [[ "$os" == "windows" ]]; then
    unzip -q "$archive" -d "$tmp_dir/archive"
    bin_name="${APP}.exe"
  else
    tar -xzf "$archive" -C "$tmp_dir"
    bin_name="$APP"
  fi

  if [[ ! -f "${tmp_dir}/${bin_name}" && ! -f "${tmp_dir}/archive/${bin_name}" ]]; then
    echo "Downloaded snapshot archive does not contain ${bin_name}" >&2
    exit 1
  fi

  if [[ -f "${tmp_dir}/archive/${bin_name}" ]]; then
    cp "${tmp_dir}/archive/${bin_name}" "${install_dir}/${bin_name}"
  else
    cp "${tmp_dir}/${bin_name}" "${install_dir}/${bin_name}"
  fi
  chmod +x "${install_dir}/${bin_name}"
}

install_from_archive() {
  local os arch version ext filename url tmp_dir archive bin_name
  os=$(detect_os)
  arch=$(detect_arch)
  version=$(resolve_version)

  ext="tar.gz"
  if [[ "$os" == "windows" ]]; then
    ext="zip"
  fi

  filename="${APP}_${version}_${os}_${arch}.${ext}"
  url=$(resolve_asset_url "$version" "$os" "$arch" "$ext")
  if [[ -z "$url" ]]; then
    url="https://github.com/${OWNER}/${REPO}/releases/download/v${version}/${filename}"
  fi

  echo "Installing ${APP} v${version} (${os}/${arch})"

  tmp_dir=$(mktemp -d)
  archive="${tmp_dir}/${filename}"
  trap '[[ -n "${tmp_dir:-}" ]] && rm -rf "$tmp_dir"' EXIT

  if ! curl -fL "$url" -o "$archive"; then
    echo "Failed to download release artifact: $url" >&2
    exit 1
  fi

  if [[ "$os" == "windows" ]]; then
    if ! command -v unzip >/dev/null 2>&1; then
      echo "Error: unzip is required to install on Windows" >&2
      exit 1
    fi
    unzip -q "$archive" -d "$tmp_dir"
    bin_name="${APP}.exe"
  else
    if ! command -v tar >/dev/null 2>&1; then
      echo "Error: tar is required to install" >&2
      exit 1
    fi
    tar -xzf "$archive" -C "$tmp_dir"
    bin_name="$APP"
  fi

  if [[ ! -f "${tmp_dir}/${bin_name}" ]]; then
    echo "Downloaded archive does not contain ${bin_name}" >&2
    exit 1
  fi

  cp "${tmp_dir}/${bin_name}" "${install_dir}/${bin_name}"
  chmod +x "${install_dir}/${bin_name}"
}

install_from_binary() {
  local src_name dst_name
  if [[ ! -f "$binary_path" ]]; then
    echo "Binary not found: $binary_path" >&2
    exit 1
  fi

  src_name=$(basename "$binary_path")
  dst_name="$APP"
  if [[ "$src_name" == *.exe ]]; then
    dst_name="${APP}.exe"
  fi

  cp "$binary_path" "${install_dir}/${dst_name}"
  chmod +x "${install_dir}/${dst_name}"
}

add_path() {
  if [[ ":$PATH:" == *":${install_dir}:"* ]]; then
    return
  fi

  local line file
  line="export PATH=\"${install_dir}:\$PATH\""

  for file in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.profile"; do
    if [[ -f "$file" ]]; then
      if ! grep -Fxq "$line" "$file"; then
        printf "\n# wingman\n%s\n" "$line" >> "$file"
        echo "Added ${install_dir} to PATH in ${file}"
      fi
      return
    fi
  done

  echo "Add this to your shell config to use ${APP}:"
  echo "  ${line}"
}

if [[ "$install_snapshot" == true ]]; then
  install_from_snapshot
elif [[ -n "$binary_path" ]]; then
  install_from_binary
else
  install_from_archive
fi

if [[ "$no_modify_path" == false ]] && confirm "Add ${install_dir} to PATH in your shell config?" yes; then
  add_path
fi

echo
echo "Installed ${APP} to ${install_dir}"
if [[ ":$PATH:" != *":${install_dir}:"* ]]; then
  echo "Add ${install_dir} to your PATH:"
  echo "  export PATH=\"${install_dir}:\$PATH\""
fi
echo "Run '${APP} version' to verify"
echo
